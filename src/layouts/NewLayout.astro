---
import "@/styles/brutalist.css";
import "@/styles/globals.css";
import "@fontsource/geist-sans/200.css";
import "@fontsource/geist-sans/300.css";
import "@fontsource/geist-sans/400.css";
import "@fontsource/geist-sans/500.css";
import "@fontsource/geist-sans/600.css";
import "@fontsource/geist-sans/700.css";
import "@fontsource/geist-sans/800.css";
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <title>Fabian Montoya | Portfolio</title>
    <meta name="description" content="Fabian Montoya's personal website - Full Stack Developer" />
  </head>
  <body class="font-display bg-brutalist-black text-brutalist-white min-h-screen overflow-x-hidden">
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    font-family: "Geist Sans", sans-serif;
  }
</style>