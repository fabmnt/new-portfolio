---
import LinkedInIcon from "@/assets/icons/LinkedInIcon.astro";
import GithubIcon from "@/assets/icons/GithubIcon.astro";
import TwitterIcon from "@/assets/icons/TwitterIcon.astro";
import type { TranslationKeys } from "@/i18n";
import { getTranslations } from "@/i18n";

interface Props {
  locale: "en" | "es";
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const currentYear = new Date().getFullYear();
---

<footer class="relative py-12 overflow-hidden bg-brutalist-black">
  <div class="absolute inset-0 bg-brutalist-black"></div>
  <div class="absolute inset-0 bg-section-pattern opacity-60"></div>
  <div class="absolute inset-x-0 top-0 h-40 bg-section-fade-top"></div>
  <div class="absolute top-1/3 left-1/4 w-1/2 h-1/2 bg-section-glow"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 md:px-8 lg:px-8">
    <div class="animate-on-scroll mb-12 text-center">
      <h2
        class="text-center text-3xl sm:text-4xl md:text-4xl lg:text-5xl font-extrabold text-brutalist-white mb-4 title-fade"
        data-title={t.footer.title}
      >
        {t.footer.title}
      </h2>
      <p class="text-brutalist-white/80 font-light max-w-md mx-auto">
        {t.footer.description}
      </p>
    </div>

    <div
      class="animate-on-scroll delay-100 flex flex-col sm:flex-row items-center justify-center gap-6 mb-12"
    >
      <a
        href="mailto:fabianmontoya2802@gmail.com"
        class="primary-metal-button inline-flex items-center gap-3 text-brutalist-white px-8 py-4 font-medium tracking-wider uppercase text-sm group"
      >
        <svg
          class="size-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width={2}
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          ></path>
        </svg>
        {t.footer.sendEmail}
        <svg
          class="size-4 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width={2}
            d="M7 17L17 7M17 7H7M17 7V17"></path>
        </svg>
      </a>

      <div class="flex items-center gap-3">
        <a
          href="https://www.linkedin.com/in/fabián-montoya-963247345"
          target="_blank"
          rel="noopener noreferrer"
          class="secondary-metal-button p-3 border border-brutalist-white/20 text-brutalist-white"
          aria-label={`LinkedIn (${locale === "es" ? "abre en nueva pestaña" : "opens in new tab"})`}
        >
          <LinkedInIcon class="!size-5" aria-hidden="true" />
        </a>
        <a
          href="https://x.com/fabmntp"
          target="_blank"
          rel="noopener noreferrer"
          class="secondary-metal-button p-3 border border-brutalist-white/20 text-brutalist-white"
          aria-label={`X (${locale === "es" ? "abre en nueva pestaña" : "opens in new tab"})`}
        >
          <TwitterIcon class="!size-5" aria-hidden="true" />
        </a>
        <a
          href="https://github.com/fabmnt"
          target="_blank"
          rel="noopener noreferrer"
          class="secondary-metal-button p-3 border border-brutalist-white/20 text-brutalist-white"
          aria-label={`GitHub (${locale === "es" ? "abre en nueva pestaña" : "opens in new tab"})`}
        >
          <GithubIcon class="!size-5" aria-hidden="true" />
        </a>
      </div>
    </div>

    <div
      class="animate-on-scroll delay-200 pt-8 border-t border-brutalist-white/10 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <a
        href="mailto:fabianmontoya2802@gmail.com"
        class="text-brutalist-white/40 text-sm font-light hover:text-brutalist-blue transition-colors"
      >
        fabianmontoya2802@gmail.com
      </a>
      <div class="flex flex-col items-center">
        <p class="text-brutalist-white/40 text-sm font-light">
          © {currentYear} Fabian Montoya. <br />
        </p>
        <span class="text-brutalist-white/40 text-sm font-light">
          {t.footer.copyright}
        </span>
      </div>
    </div>
  </div>
</footer>
