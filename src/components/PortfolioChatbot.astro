---
import { getTranslations, type Locale } from "@/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section class="portfolio-chatbot" data-chatbot-locale={locale}>
  <button
    id="chatbot-toggle"
    type="button"
    class="chatbot-toggle"
    aria-expanded="false"
    aria-controls="chatbot-panel"
    aria-label={t.chatbot.open}
    title={t.chatbot.open}
  >
    AI
  </button>

  <div id="chatbot-panel" class="chatbot-panel" hidden>
    <header class="chatbot-header">
      <div>
        <h2>{t.chatbot.title}</h2>
        <p>{t.chatbot.subtitle}</p>
      </div>
      <button id="chatbot-close" class="chatbot-close" type="button" aria-label={t.chatbot.close}>×</button>
    </header>

    <div id="chatbot-messages" class="chatbot-messages" aria-live="polite">
      <article class="chatbot-message chatbot-assistant">{t.chatbot.welcome}</article>
    </div>

    <form id="chatbot-form" class="chatbot-form">
      <label class="sr-only" for="chatbot-input">{t.chatbot.placeholder}</label>
      <input
        id="chatbot-input"
        name="message"
        type="text"
        maxlength="280"
        placeholder={t.chatbot.placeholder}
        autocomplete="off"
        required
      />
      <button type="submit">{t.chatbot.send}</button>
    </form>
  </div>
</section>

<script is:inline define:vars={{
  locale,
  loadingMessage: t.chatbot.loading,
  errorMessage: t.chatbot.error,
  openLabel: t.chatbot.open,
  closeLabel: t.chatbot.close,
}}>
  (() => {
    const panel = document.getElementById("chatbot-panel");
    const toggleButton = document.getElementById("chatbot-toggle");
    const closeButton = document.getElementById("chatbot-close");
    const form = document.getElementById("chatbot-form");
    const input = document.getElementById("chatbot-input");
    const messagesBox = document.getElementById("chatbot-messages");

    if (!panel || !toggleButton || !closeButton || !form || !input || !messagesBox) {
      return;
    }

    const conversation = [];

    function appendMessage(content, role) {
      const article = document.createElement("article");
      article.className = `chatbot-message ${role === "assistant" ? "chatbot-assistant" : "chatbot-user"}`;
      article.textContent = content;
      messagesBox.appendChild(article);
      messagesBox.scrollTop = messagesBox.scrollHeight;
      return article;
    }

    function setPanelOpen(open) {
      panel.hidden = !open;
      toggleButton.setAttribute("aria-expanded", String(open));
      toggleButton.setAttribute("aria-label", open ? closeLabel : openLabel);
      toggleButton.setAttribute("title", open ? closeLabel : openLabel);
      if (open) input.focus();
    }

    async function submitMessage(text) {
      conversation.push({ role: "user", content: text });
      appendMessage(text, "user");

      const loadingNode = appendMessage(loadingMessage, "assistant");

      try {
        const response = await fetch("/api/chatbot", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ locale, messages: conversation }),
        });

        const data = await response.json();
        loadingNode.remove();

        if (!response.ok || !data.reply) {
          appendMessage(errorMessage, "assistant");
          return;
        }

        conversation.push({ role: "assistant", content: data.reply });
        appendMessage(data.reply, "assistant");
      } catch {
        loadingNode.remove();
        appendMessage(errorMessage, "assistant");
      }
    }

    toggleButton.addEventListener("click", () => setPanelOpen(panel.hidden));
    closeButton.addEventListener("click", () => setPanelOpen(false));

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const value = input.value.trim();
      if (!value) return;

      input.value = "";
      submitMessage(value);
    });
  })();
</script>

<style>
  .portfolio-chatbot {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 80;
  }

  .chatbot-toggle {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 999px;
    border: 2px solid rgb(37, 99, 235);
    background: rgb(59, 130, 246);
    color: #fff;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
  }

  .chatbot-panel {
    width: min(22rem, calc(100vw - 2rem));
    height: 30rem;
    display: grid;
    grid-template-rows: auto 1fr auto;
    overflow: hidden;
    border: 2px solid rgb(30, 64, 175);
    border-radius: 0.75rem;
    background: rgb(2, 6, 23);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.45);
  }

  .chatbot-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    padding: 0.85rem;
  }

  .chatbot-header h2 {
    margin: 0;
    font-size: 0.95rem;
  }

  .chatbot-header p {
    margin: 0.25rem 0 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.72rem;
  }

  .chatbot-close {
    border: 0;
    background: transparent;
    color: #fff;
    font-size: 1.3rem;
    cursor: pointer;
    line-height: 1;
  }

  .chatbot-messages {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    overflow-y: auto;
    padding: 0.85rem;
  }

  .chatbot-message {
    border-radius: 0.65rem;
    padding: 0.65rem 0.75rem;
    font-size: 0.83rem;
    line-height: 1.4;
    white-space: pre-wrap;
  }

  .chatbot-assistant {
    background: rgba(148, 163, 184, 0.25);
    align-self: flex-start;
  }

  .chatbot-user {
    background: rgb(37, 99, 235);
    align-self: flex-end;
  }

  .chatbot-form {
    display: grid;
    gap: 0.6rem;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding: 0.85rem;
  }

  .chatbot-form input {
    width: 100%;
    border: 1px solid rgba(148, 163, 184, 0.55);
    border-radius: 0.5rem;
    background: rgba(15, 23, 42, 0.65);
    color: #fff;
    padding: 0.55rem 0.65rem;
    font-size: 0.84rem;
  }

  .chatbot-form button {
    border: 1px solid rgb(37, 99, 235);
    border-radius: 0.5rem;
    background: rgb(37, 99, 235);
    color: #fff;
    padding: 0.5rem 0.75rem;
    font-size: 0.84rem;
    font-weight: 700;
    cursor: pointer;
  }

  .chatbot-form button:hover,
  .chatbot-toggle:hover {
    filter: brightness(1.07);
  }

  @media (max-width: 720px) {
    .chatbot-panel {
      height: min(30rem, calc(100vh - 5.25rem));
    }
  }
</style>
