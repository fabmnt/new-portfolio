<script is:inline>
  (() => {
    const root = window;

    if (!root.__setupHoverLights) {
      const clampHoverValue = (value) => Math.min(100, Math.max(0, value));

      const updateHoverLight = (element, event) => {
        const bounds = element.getBoundingClientRect();
        const x = ((event.clientX - bounds.left) / bounds.width) * 100;
        const y = ((event.clientY - bounds.top) / bounds.height) * 100;

        element.style.setProperty("--hover-x", `${clampHoverValue(x).toFixed(2)}%`);
        element.style.setProperty("--hover-y", `${clampHoverValue(y).toFixed(2)}%`);
      };

      const setTouchActive = (element, isActive) => {
        if (isActive) {
          element.dataset.touchActive = "true";
          return;
        }

        delete element.dataset.touchActive;
      };

      root.__setupHoverLights = () => {
        document.querySelectorAll("[data-hover-light]").forEach((element) => {
          if (element.dataset.hoverLightReady === "true") {
            return;
          }

          const handlePointer = (event) => {
            window.requestAnimationFrame(() => updateHoverLight(element, event));

            if (event.pointerType === "touch") {
              setTouchActive(element, true);
            }
          };

          const clearTouchActive = (event) => {
            if (event.pointerType === "touch") {
              setTouchActive(element, false);
            }
          };

          element.addEventListener("pointerdown", handlePointer);
          element.addEventListener("pointerenter", handlePointer);
          element.addEventListener("pointermove", handlePointer);
          element.addEventListener("pointerup", clearTouchActive);
          element.addEventListener("pointercancel", clearTouchActive);
          element.dataset.hoverLightReady = "true";
        });
      };

      document.addEventListener("astro:page-load", root.__setupHoverLights);
    }

    root.__setupHoverLights();
  })();
</script>
