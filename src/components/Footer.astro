---
import { getTranslations } from "@/i18n";

interface Props {
  locale: "en" | "es";
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const currentYear = new Date().getFullYear();
---

<footer class="relative overflow-hidden bg-brutalist-black pt-12 pb-12">
  <div class="absolute inset-0 bg-brutalist-black"></div>
  <div class="absolute inset-x-0 top-0 h-40 bg-section-fade-top"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 md:px-8 lg:px-8">
    <div
      class="animate-on-scroll delay-200 flex flex-col items-center justify-between gap-4 border-t border-brutalist-white/10 pt-10 sm:flex-row"
    >
      <a
        href="mailto:fabianmontoya2802@gmail.com"
        class="text-sm font-light text-brutalist-white/40 transition-colors hover:text-brutalist-blue"
      >
        fabianmontoya2802@gmail.com
      </a>
      <div class="flex flex-col items-center">
        <p class="text-sm font-light text-brutalist-white/40">
          © {currentYear} Fabian Montoya. <br />
        </p>
        <span class="text-sm font-light text-brutalist-white/40">
          {t.footer.copyright}
        </span>
      </div>
    </div>
  </div>
</footer>
