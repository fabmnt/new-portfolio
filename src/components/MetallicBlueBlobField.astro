---
interface Props {
  class?: string;
}

const {
  class: className = "",
} = Astro.props;
---

<div
  class={`metallic-blob-field ${className}`}
  data-metallic-blob-field
  aria-hidden="true"
>
  <div class="metallic-blob-field__halo"></div>
  <div class="metallic-blob-field__aura metallic-blob-field__aura--outer"></div>
  <div class="metallic-blob-field__aura metallic-blob-field__aura--inner"></div>
  <div class="metallic-blob-field__core-wrap">
    <div class="metallic-blob-field__core-shell">
      <div class="metallic-blob-field__ring metallic-blob-field__ring--one"></div>
      <div class="metallic-blob-field__ring metallic-blob-field__ring--two"></div>
      <div class="metallic-blob-field__core"></div>
    </div>
  </div>
</div>

<style is:global>
  .metallic-blob-field {
    position: absolute;
    inset: -18%;
    z-index: 0;
    overflow: visible;
    pointer-events: none;
    isolation: isolate;
    perspective: 1200px;
    --blob-shift-x: 0px;
    --blob-shift-y: 0px;
    --blob-soft-x: 0px;
    --blob-soft-y: 0px;
    --blob-aura-x: 0px;
    --blob-aura-y: 0px;
    --blob-tilt-x: 0deg;
    --blob-tilt-y: 0deg;
    --blob-scale: 1;
    --blob-gloss-x: 30%;
    --blob-gloss-y: 24%;
    --blob-r1: 44%;
    --blob-r2: 56%;
    --blob-r3: 61%;
    --blob-r4: 39%;
    --blob-r5: 40%;
    --blob-r6: 36%;
    --blob-r7: 64%;
    --blob-r8: 60%;
  }

  .metallic-blob-field__halo {
    position: absolute;
    inset: 8%;
    border-radius: 50%;
    background:
      radial-gradient(circle at 50% 50%, rgba(96, 165, 250, 0.2) 0%, rgba(59, 130, 246, 0.14) 28%, rgba(29, 78, 216, 0.08) 48%, rgba(15, 23, 42, 0) 72%),
      radial-gradient(circle at 46% 44%, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0) 24%);
    filter: blur(32px);
    opacity: 0.95;
    transform: translate3d(var(--blob-soft-x), var(--blob-soft-y), 0);
    transition: transform 180ms ease-out;
  }

  .metallic-blob-field__aura {
    position: absolute;
    inset: 12%;
    border-radius: 999px;
    pointer-events: none;
  }

  .metallic-blob-field__aura--outer {
    background:
      radial-gradient(circle at 24% 24%, rgba(255, 255, 255, 0.48) 0%, rgba(191, 219, 254, 0.34) 16%, rgba(96, 165, 250, 0.24) 34%, rgba(37, 99, 235, 0.18) 52%, rgba(15, 23, 42, 0) 78%),
      radial-gradient(circle at 72% 68%, rgba(30, 64, 175, 0.24) 0%, rgba(30, 58, 138, 0.14) 38%, rgba(15, 23, 42, 0) 74%);
    filter: blur(34px);
    opacity: 0.82;
    transform: translate3d(var(--blob-aura-x), var(--blob-aura-y), 0) scale(1.16);
    transition: transform 200ms ease-out;
  }

  .metallic-blob-field__aura--inner {
    inset: 22%;
    background:
      conic-gradient(from 215deg at 50% 50%, rgba(191, 219, 254, 0.14), rgba(59, 130, 246, 0.4), rgba(30, 64, 175, 0.1), rgba(224, 242, 254, 0.16), rgba(37, 99, 235, 0.2), rgba(191, 219, 254, 0.14)),
      radial-gradient(circle at 48% 44%, rgba(255, 255, 255, 0.16) 0%, rgba(96, 165, 250, 0.18) 34%, rgba(15, 23, 42, 0) 70%);
    filter: blur(22px);
    opacity: 0.72;
    transform: translate3d(var(--blob-soft-x), var(--blob-soft-y), 0) scale(0.98);
    transition: transform 180ms ease-out;
  }

  .metallic-blob-field__core-wrap {
    position: absolute;
    inset: 24%;
    display: grid;
    place-items: center;
    pointer-events: none;
    transform: translate3d(var(--blob-soft-x), var(--blob-soft-y), 0);
    transition: transform 160ms ease-out;
  }

  .metallic-blob-field__core-shell {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    animation: metallic-core-breathe 8s ease-in-out infinite alternate;
  }

  .metallic-blob-field__core {
    position: relative;
    width: 100%;
    height: 100%;
    border: 1px solid rgba(191, 219, 254, 0.28);
    border-radius: var(--blob-r1) var(--blob-r2) var(--blob-r3) var(--blob-r4) / var(--blob-r5) var(--blob-r6) var(--blob-r7) var(--blob-r8);
    background:
      radial-gradient(circle at var(--blob-gloss-x) var(--blob-gloss-y), rgba(255, 255, 255, 0.95) 0 10%, rgba(224, 242, 254, 0.72) 16%, rgba(125, 211, 252, 0.55) 26%, rgba(59, 130, 246, 0.78) 44%, rgba(37, 99, 235, 0.92) 58%, rgba(30, 64, 175, 0.9) 78%, rgba(15, 23, 42, 0.4) 100%),
      linear-gradient(150deg, rgba(255, 255, 255, 0.26), rgba(191, 219, 254, 0.1) 34%, rgba(59, 130, 246, 0.36) 54%, rgba(30, 64, 175, 0.88) 100%);
    box-shadow:
      0 0 70px rgba(59, 130, 246, 0.26),
      0 0 140px rgba(29, 78, 216, 0.14),
      inset 18px 16px 26px rgba(255, 255, 255, 0.18),
      inset -24px -20px 34px rgba(15, 23, 42, 0.34);
    filter: saturate(1.18) brightness(1.06);
    transform: translate3d(var(--blob-shift-x), var(--blob-shift-y), 0) rotateX(var(--blob-tilt-x)) rotateY(var(--blob-tilt-y)) scale(var(--blob-scale));
    transition: transform 120ms ease-out, border-radius 160ms ease-out, box-shadow 160ms ease-out, filter 160ms ease-out;
    will-change: transform, border-radius;
  }

  .metallic-blob-field__core::before,
  .metallic-blob-field__core::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
  }

  .metallic-blob-field__core::before {
    inset: 14% 20% auto 16%;
    height: 26%;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0));
    filter: blur(10px);
    opacity: 0.92;
    transform: rotate(-12deg);
  }

  .metallic-blob-field__core::after {
    inset: 8%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    opacity: 0.6;
  }

  .metallic-blob-field__ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(191, 219, 254, 0.16);
    box-shadow: 0 0 30px rgba(59, 130, 246, 0.1);
    opacity: 0.7;
  }

  .metallic-blob-field__ring--one {
    inset: -12%;
    border-radius: 43% 57% 52% 48% / 45% 40% 60% 55%;
    animation: metallic-ring-float 10s linear infinite;
  }

  .metallic-blob-field__ring--two {
    inset: -26%;
    border-radius: 55% 45% 48% 52% / 48% 56% 44% 52%;
    opacity: 0.45;
    animation: metallic-ring-float 16s linear infinite reverse;
  }

  @media (max-width: 767px) {
    .metallic-blob-field {
      inset: -12%;
    }

    .metallic-blob-field__core-wrap {
      inset: 22%;
    }
  }

  @keyframes metallic-ring-float {
    from {
      transform: rotate(0deg) scale(0.98);
    }

    to {
      transform: rotate(360deg) scale(1.02);
    }
  }

  @keyframes metallic-core-breathe {
    0% {
      transform: rotate(-5deg) scale(0.98);
    }

    50% {
      transform: rotate(2deg) scale(1.02);
    }

    100% {
      transform: rotate(7deg) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .metallic-blob-field__core-shell,
    .metallic-blob-field__ring--one,
    .metallic-blob-field__ring--two {
      animation: none;
    }
  }
</style>

<script>
  (() => {
    const fields = document.querySelectorAll("[data-metallic-blob-field]");

    if (!fields.length) {
      return;
    }

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    fields.forEach((field) => {
      if (field.dataset.initialized === "true") {
        return;
      }

      field.dataset.initialized = "true";

      const host = field.closest("[data-blob-host]") ?? field.parentElement ?? field;
      const intensity = prefersReducedMotion ? 0.4 : 1;

      const setVariables = (variables) => {
        Object.entries(variables).forEach(([name, value]) => {
          field.style.setProperty(name, value);
        });
      };

      const resetVariables = () => {
        setVariables({
          "--blob-shift-x": "0px",
          "--blob-shift-y": "0px",
          "--blob-soft-x": "0px",
          "--blob-soft-y": "0px",
          "--blob-aura-x": "0px",
          "--blob-aura-y": "0px",
          "--blob-tilt-x": "0deg",
          "--blob-tilt-y": "0deg",
          "--blob-scale": "1",
          "--blob-gloss-x": "30%",
          "--blob-gloss-y": "24%",
          "--blob-r1": "44%",
          "--blob-r2": "56%",
          "--blob-r3": "61%",
          "--blob-r4": "39%",
          "--blob-r5": "40%",
          "--blob-r6": "36%",
          "--blob-r7": "64%",
          "--blob-r8": "60%",
        });
      };

      const updateFromPointer = (event) => {
        const bounds = host.getBoundingClientRect();

        if (!bounds.width || !bounds.height) {
          return;
        }

        const x = clamp((event.clientX - bounds.left) / bounds.width, 0, 1);
        const y = clamp((event.clientY - bounds.top) / bounds.height, 0, 1);
        const offsetX = (x - 0.5) * 2;
        const offsetY = (y - 0.5) * 2;

        setVariables({
          "--blob-shift-x": `${(offsetX * 16 * intensity).toFixed(2)}px`,
          "--blob-shift-y": `${(offsetY * 16 * intensity).toFixed(2)}px`,
          "--blob-soft-x": `${(offsetX * 8 * intensity).toFixed(2)}px`,
          "--blob-soft-y": `${(offsetY * 8 * intensity).toFixed(2)}px`,
          "--blob-aura-x": `${(offsetX * 12 * intensity).toFixed(2)}px`,
          "--blob-aura-y": `${(offsetY * 12 * intensity).toFixed(2)}px`,
          "--blob-tilt-x": `${(-offsetY * 9 * intensity).toFixed(2)}deg`,
          "--blob-tilt-y": `${(offsetX * 9 * intensity).toFixed(2)}deg`,
          "--blob-scale": `${(1 + Math.min(0.05, Math.hypot(offsetX, offsetY) * 0.035 * intensity)).toFixed(3)}`,
          "--blob-gloss-x": `${(22 + x * 26).toFixed(2)}%`,
          "--blob-gloss-y": `${(16 + y * 24).toFixed(2)}%`,
          "--blob-r1": `${clamp(44 + (-offsetX * 8 - offsetY * 5) * intensity, 34, 62).toFixed(2)}%`,
          "--blob-r2": `${clamp(56 + (offsetX * 7 - offsetY * 4) * intensity, 38, 66).toFixed(2)}%`,
          "--blob-r3": `${clamp(61 + (offsetX * 5 + offsetY * 7) * intensity, 40, 70).toFixed(2)}%`,
          "--blob-r4": `${clamp(39 + (-offsetX * 6 + offsetY * 5) * intensity, 30, 58).toFixed(2)}%`,
          "--blob-r5": `${clamp(40 + (-offsetX * 4 - offsetY * 7) * intensity, 30, 62).toFixed(2)}%`,
          "--blob-r6": `${clamp(36 + (offsetX * 6 - offsetY * 6) * intensity, 26, 58).toFixed(2)}%`,
          "--blob-r7": `${clamp(64 + (offsetX * 5 + offsetY * 6) * intensity, 42, 72).toFixed(2)}%`,
          "--blob-r8": `${clamp(60 + (-offsetX * 7 + offsetY * 5) * intensity, 40, 72).toFixed(2)}%`,
        });
      };

      const updateFromTouch = (event) => {
        const touch = event.touches[0];

        if (!touch) {
          return;
        }

        updateFromPointer({
          clientX: touch.clientX,
          clientY: touch.clientY,
        });
      };

      resetVariables();

      host.addEventListener("pointerdown", (event) => {
        updateFromPointer(event);

        if (typeof host.setPointerCapture === "function") {
          try {
            host.setPointerCapture(event.pointerId);
          } catch {
          }
        }
      });

      host.addEventListener("pointermove", (event) => {
        updateFromPointer(event);
      });

      host.addEventListener("pointerup", () => {
        resetVariables();
      });

      host.addEventListener("pointercancel", () => {
        resetVariables();
      });

      host.addEventListener("pointerleave", () => {
        resetVariables();
      });

      host.addEventListener("touchstart", updateFromTouch, { passive: true });
      host.addEventListener("touchmove", updateFromTouch, { passive: true });
      host.addEventListener("touchend", () => {
        resetVariables();
      }, { passive: true });

      host.addEventListener("touchcancel", () => {
        resetVariables();
      }, { passive: true });
    });
  })();
</script>
