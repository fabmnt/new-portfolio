---
interface Props {
  class?: string;
  blobCount?: number;
  hoverBurst?: number;
}

const {
  class: className = "",
  blobCount = 24,
  hoverBurst = 5,
} = Astro.props;
---

<div
  class={`metallic-blob-field ${className}`}
  data-metallic-blob-field
  data-blob-count={blobCount}
  data-hover-burst={hoverBurst}
  aria-hidden="true"
>
  <div class="metallic-blob-field__halo"></div>
  <div class="metallic-blob-field__aura metallic-blob-field__aura--outer"></div>
  <div class="metallic-blob-field__aura metallic-blob-field__aura--inner"></div>
  <div class="metallic-blob-field__core-wrap">
    <div class="metallic-blob-field__ring metallic-blob-field__ring--one"></div>
    <div class="metallic-blob-field__ring metallic-blob-field__ring--two"></div>
    <div class="metallic-blob-field__core"></div>
  </div>
</div>

<style is:global>
  .metallic-blob-field {
    position: absolute;
    inset: -18%;
    z-index: 0;
    overflow: visible;
    pointer-events: none;
    isolation: isolate;
  }

  .metallic-blob-field__halo {
    position: absolute;
    inset: 8%;
    border-radius: 50%;
    background:
      radial-gradient(circle at 50% 50%, rgba(96, 165, 250, 0.2) 0%, rgba(59, 130, 246, 0.14) 28%, rgba(29, 78, 216, 0.08) 48%, rgba(15, 23, 42, 0) 72%),
      radial-gradient(circle at 46% 44%, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0) 24%);
    filter: blur(32px);
    opacity: 0.95;
  }

  .metallic-blob-field__aura {
    position: absolute;
    inset: 12%;
    border-radius: 999px;
    pointer-events: none;
  }

  .metallic-blob-field__aura--outer {
    background:
      radial-gradient(circle at 24% 24%, rgba(255, 255, 255, 0.48) 0%, rgba(191, 219, 254, 0.34) 16%, rgba(96, 165, 250, 0.24) 34%, rgba(37, 99, 235, 0.18) 52%, rgba(15, 23, 42, 0) 78%),
      radial-gradient(circle at 72% 68%, rgba(30, 64, 175, 0.24) 0%, rgba(30, 58, 138, 0.14) 38%, rgba(15, 23, 42, 0) 74%);
    filter: blur(34px);
    opacity: 0.82;
    transform: scale(1.16);
  }

  .metallic-blob-field__aura--inner {
    inset: 22%;
    background:
      conic-gradient(from 215deg at 50% 50%, rgba(191, 219, 254, 0.14), rgba(59, 130, 246, 0.4), rgba(30, 64, 175, 0.1), rgba(224, 242, 254, 0.16), rgba(37, 99, 235, 0.2), rgba(191, 219, 254, 0.14)),
      radial-gradient(circle at 48% 44%, rgba(255, 255, 255, 0.16) 0%, rgba(96, 165, 250, 0.18) 34%, rgba(15, 23, 42, 0) 70%);
    filter: blur(22px);
    opacity: 0.72;
    transform: scale(0.98);
  }

  .metallic-blob-field__core-wrap {
    position: absolute;
    inset: 24%;
    display: grid;
    place-items: center;
    pointer-events: none;
  }

  .metallic-blob-field__core {
    position: relative;
    width: 100%;
    height: 100%;
    border: 1px solid rgba(191, 219, 254, 0.28);
    border-radius: 44% 56% 61% 39% / 40% 36% 64% 60%;
    background:
      radial-gradient(circle at 30% 24%, rgba(255, 255, 255, 0.95) 0 10%, rgba(224, 242, 254, 0.72) 16%, rgba(125, 211, 252, 0.55) 26%, rgba(59, 130, 246, 0.78) 44%, rgba(37, 99, 235, 0.92) 58%, rgba(30, 64, 175, 0.9) 78%, rgba(15, 23, 42, 0.4) 100%),
      linear-gradient(150deg, rgba(255, 255, 255, 0.26), rgba(191, 219, 254, 0.1) 34%, rgba(59, 130, 246, 0.36) 54%, rgba(30, 64, 175, 0.88) 100%);
    box-shadow:
      0 0 70px rgba(59, 130, 246, 0.26),
      0 0 140px rgba(29, 78, 216, 0.14),
      inset 18px 16px 26px rgba(255, 255, 255, 0.18),
      inset -24px -20px 34px rgba(15, 23, 42, 0.34);
    filter: saturate(1.18) brightness(1.06);
    animation: metallic-core-drift 8s ease-in-out infinite alternate;
  }

  .metallic-blob-field__core::before,
  .metallic-blob-field__core::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
  }

  .metallic-blob-field__core::before {
    inset: 14% 20% auto 16%;
    height: 26%;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0));
    filter: blur(10px);
    opacity: 0.92;
    transform: rotate(-12deg);
  }

  .metallic-blob-field__core::after {
    inset: 8%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    opacity: 0.6;
  }

  .metallic-blob-field__ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(191, 219, 254, 0.16);
    box-shadow: 0 0 30px rgba(59, 130, 246, 0.1);
    opacity: 0.7;
  }

  .metallic-blob-field__ring--one {
    inset: -12%;
    border-radius: 43% 57% 52% 48% / 45% 40% 60% 55%;
    animation: metallic-ring-float 10s linear infinite;
  }

  .metallic-blob-field__ring--two {
    inset: -26%;
    border-radius: 55% 45% 48% 52% / 48% 56% 44% 52%;
    opacity: 0.45;
    animation: metallic-ring-float 16s linear infinite reverse;
  }

  .metallic-blob-field__blob {
    position: absolute;
    left: 0;
    top: 0;
    display: block;
    border: 1px solid rgba(191, 219, 254, 0.24);
    border-radius: var(--blob-shape);
    opacity: 0;
    pointer-events: none;
    transform: translate3d(-50%, -50%, 0) scale(0.6);
    transform-origin: center;
    will-change: transform, opacity;
    background:
      radial-gradient(circle at 28% 24%, rgba(255, 255, 255, 0.98) 0 8%, rgba(224, 242, 254, 0.88) 14%, rgba(147, 197, 253, 0.84) 24%, rgba(59, 130, 246, 0.68) 42%, rgba(29, 78, 216, 0.78) 64%, rgba(7, 18, 51, 0.3) 84%, rgba(7, 18, 51, 0) 100%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.22), rgba(96, 165, 250, 0.08) 36%, rgba(30, 64, 175, 0.44) 76%, rgba(15, 23, 42, 0.34) 100%);
    box-shadow:
      0 0 22px rgba(59, 130, 246, 0.16),
      inset 10px 12px 18px rgba(255, 255, 255, 0.16),
      inset -12px -14px 22px rgba(15, 23, 42, 0.32);
    filter: blur(var(--blob-blur, 2px)) saturate(1.16) brightness(1.08) hue-rotate(var(--blob-hue, 0deg));
    mix-blend-mode: screen;
  }

  .metallic-blob-field__blob::before,
  .metallic-blob-field__blob::after {
    content: "";
    position: absolute;
    pointer-events: none;
  }

  .metallic-blob-field__blob::before {
    inset: 14% 20% auto 16%;
    height: 32%;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0));
    filter: blur(7px);
    opacity: 0.9;
    transform: rotate(-9deg);
  }

  .metallic-blob-field__blob::after {
    inset: 10%;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: inherit;
    opacity: 0.72;
  }

  @media (max-width: 767px) {
    .metallic-blob-field {
      inset: -12%;
    }

    .metallic-blob-field__core-wrap {
      inset: 22%;
    }
  }

  @keyframes metallic-ring-float {
    from {
      transform: rotate(0deg) scale(0.98);
    }

    to {
      transform: rotate(360deg) scale(1.02);
    }
  }

  @keyframes metallic-core-drift {
    0% {
      border-radius: 44% 56% 61% 39% / 40% 36% 64% 60%;
      transform: rotate(-5deg) scale(0.98);
    }

    50% {
      border-radius: 58% 42% 48% 52% / 48% 62% 38% 52%;
      transform: rotate(2deg) scale(1.02);
    }

    100% {
      border-radius: 49% 51% 39% 61% / 56% 42% 58% 44%;
      transform: rotate(7deg) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .metallic-blob-field__core,
    .metallic-blob-field__ring--one,
    .metallic-blob-field__ring--two {
      animation: none;
    }
  }
</style>

<script>
  (() => {
    const fields = document.querySelectorAll("[data-metallic-blob-field]");

    if (!fields.length) {
      return;
    }

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
    const randomBetween = (min, max) => min + Math.random() * (max - min);
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const makeShape = () => {
      const values = Array.from({ length: 8 }, () => Math.round(randomBetween(32, 68)));
      return `${values[0]}% ${values[1]}% ${values[2]}% ${values[3]}% / ${values[4]}% ${values[5]}% ${values[6]}% ${values[7]}%`;
    };

    fields.forEach((field) => {
      if (field.dataset.initialized === "true") {
        return;
      }

      field.dataset.initialized = "true";

      const host = field.closest("[data-blob-host]") ?? field.parentElement ?? field;
      const baseCount = Number.parseInt(field.dataset.blobCount ?? "24", 10) || 24;
      const hoverBurst = Number.parseInt(field.dataset.hoverBurst ?? "5", 10) || 5;
      const activeBlobs = new Set();
      let lastPointerMove = 0;

      const removeBlob = (blob) => {
        activeBlobs.delete(blob);
        blob.remove();
      };

      const spawnBlob = ({ x, y, interactive = false } = {}) => {
        const activeLimit = prefersReducedMotion ? Math.max(10, Math.round(baseCount / 2)) : baseCount + hoverBurst + 10;

        if (activeBlobs.size >= activeLimit) {
          return;
        }

        const blob = document.createElement("span");
        const width = interactive ? 36 : randomBetween(56, 148);
        const height = interactive ? 36 : width * randomBetween(0.72, 1.34);
        const startScale = interactive ? randomBetween(0.35, 0.72) : randomBetween(0.55, 0.92);
        const endScale = randomBetween(0.96, 1.34);
        const rotateStart = randomBetween(0, 360);
        const rotateEnd = rotateStart + randomBetween(-130, 130);
        const opacity = interactive ? randomBetween(0.52, 0.92) : randomBetween(0.28, 0.74);
        const duration = prefersReducedMotion
          ? randomBetween(1100, 2000)
          : interactive
            ? randomBetween(1500, 2600)
            : randomBetween(2800, 5200);
        const left = typeof x === "number" ? clamp(x + randomBetween(-12, 12), 4, 96) : randomBetween(10, 90);
        const top = typeof y === "number" ? clamp(y + randomBetween(-12, 12), 4, 96) : randomBetween(10, 90);
        const driftX = interactive ? randomBetween(-48, 48) : randomBetween(-74, 74);
        const driftY = interactive ? randomBetween(-42, 42) : randomBetween(-62, 62);

        blob.className = "metallic-blob-field__blob";
        blob.style.left = `${left}%`;
        blob.style.top = `${top}%`;
        blob.style.width = `${width}px`;
        blob.style.height = `${height}px`;
        blob.style.setProperty("--blob-blur", `${interactive ? 1.6 : randomBetween(1.6, 5.6)}px`);
        blob.style.setProperty("--blob-hue", `${randomBetween(-10, 8)}deg`);
        blob.style.setProperty("--blob-shape", interactive ? "50%" : makeShape());

        field.append(blob);
        activeBlobs.add(blob);

        if (typeof blob.animate !== "function") {
          blob.style.opacity = `${opacity}`;
          window.setTimeout(() => removeBlob(blob), duration);
          return;
        }

        const animation = blob.animate(
          [
            {
              opacity: 0,
              transform: `translate3d(-50%, -50%, 0) translate3d(0px, 0px, 0) rotate(${rotateStart}deg) scale(${startScale})`,
            },
            {
              opacity,
              offset: 0.18,
              transform: `translate3d(-50%, -50%, 0) translate3d(${driftX * 0.35}px, ${driftY * 0.35}px, 0) rotate(${rotateStart + (rotateEnd - rotateStart) * 0.42}deg) scale(${Math.min(1, endScale)})`,
            },
            {
              opacity: 0,
              transform: `translate3d(-50%, -50%, 0) translate3d(${driftX}px, ${driftY}px, 0) rotate(${rotateEnd}deg) scale(${endScale})`,
            },
          ],
          {
            duration,
            easing: interactive ? "cubic-bezier(0.16, 1, 0.3, 1)" : "cubic-bezier(0.22, 1, 0.36, 1)",
            fill: "forwards",
          },
        );

        animation.addEventListener("finish", () => removeBlob(blob), { once: true });
      };

      const seedAmbientBlobs = () => {
        const total = prefersReducedMotion ? Math.max(8, Math.round(baseCount / 2)) : baseCount;

        for (let index = 0; index < total; index += 1) {
          window.setTimeout(() => {
            spawnBlob();
          }, index * randomBetween(45, 110));
        }
      };

      const getRelativePoint = (event) => {
        const bounds = field.getBoundingClientRect();
        return {
          x: clamp(((event.clientX - bounds.left) / bounds.width) * 100, 0, 100),
          y: clamp(((event.clientY - bounds.top) / bounds.height) * 100, 0, 100),
        };
      };

      const spawnBurst = (event, amount) => {
        const point = getRelativePoint(event);

        for (let index = 0; index < amount; index += 1) {
          spawnBlob({ x: point.x, y: point.y, interactive: true });
        }
      };

      seedAmbientBlobs();

      const ambientInterval = window.setInterval(() => {
        const target = prefersReducedMotion ? Math.max(8, Math.round(baseCount / 2)) : baseCount;

        if (activeBlobs.size < target) {
          spawnBlob();
        }
      }, prefersReducedMotion ? 900 : 240);

      host.addEventListener("pointerenter", (event) => {
        spawnBurst(event, prefersReducedMotion ? 2 : hoverBurst);
      });

      host.addEventListener("pointermove", (event) => {
        const now = performance.now();
        const throttle = prefersReducedMotion ? 180 : 80;

        if (now - lastPointerMove < throttle) {
          return;
        }

        lastPointerMove = now;
        spawnBurst(event, prefersReducedMotion ? 1 : 2);
      });

      host.addEventListener("pointerleave", () => {
        lastPointerMove = 0;
      });

      window.addEventListener(
        "pagehide",
        () => {
          window.clearInterval(ambientInterval);
        },
        { once: true },
      );
    });
  })();
</script>
