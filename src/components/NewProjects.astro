---
import { PROJECTS } from "@/constants/projects";
import type { TranslationKeys } from "@/i18n";
import { getTranslations } from "@/i18n";

interface Props {
  locale: "en" | "es";
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section id="projects" class="relative py-20 sm:py-28 md:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-brutalist-black"></div>
  <div class="absolute inset-0 bg-section-pattern opacity-60"></div>
  <div class="absolute inset-x-0 top-0 h-40 bg-section-fade-top"></div>
  <div class="absolute inset-x-0 bottom-0 h-40 bg-section-fade-bottom"></div>
  <div class="absolute top-1/4 left-1/4 w-1/2 h-1/2 bg-section-glow"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 md:px-8 lg:px-8">
    <div class="animate-on-scroll mb-16">
      <span class="inline-block text-brutalist-white text-xs font-medium tracking-[0.3em] uppercase mb-4">
        {t.projects.subtitle}
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-brutalist-white">
        {t.projects.title} <span class="text-brutalist-blue">{t.projects.highlight}</span>
      </h2>
      <div class="mt-6 w-24 h-1 bg-brutalist-blue"></div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {PROJECTS.map((project, index) => (
        <div class={`animate-on-scroll ${index === 1 ? 'delay-100' : index === 2 ? 'delay-200' : ''}`}>
          <div class="relative bg-brutalist-white/5 backdrop-blur-sm border border-brutalist-white/10 overflow-hidden h-full">
            <div class="p-5 sm:p-6 space-y-6">
              <div class="flex items-start justify-between gap-4">
                <div class="space-y-3">
                  <div class="w-14 h-14 flex items-center justify-center border border-brutalist-white bg-brutalist-white text-brutalist-black">
                    <svg class="size-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                    </svg>
                  </div>
                  <h3 class="text-2xl font-semibold tracking-tight text-brutalist-white">
                    {project.title}
                  </h3>
                </div>
                <span class="text-xs font-medium tracking-widest px-3 py-1 border border-brutalist-white/30 text-brutalist-white/60">
                  {project.privacy === "public" ? t.projects.public : t.projects.private}
                </span>
              </div>

              <p class="text-base font-normal leading-relaxed text-brutalist-white/70">
                {t.projects.items[project.id as keyof typeof t.projects.items] || project.description}
              </p>

              <ul class="flex flex-wrap gap-3 pt-2" aria-label={locale === "es" ? "Tecnologías utilizadas" : "Technologies used"}>
                {project.techs.map((tech) => (
                  <li class="text-xs font-medium tracking-wider px-4 py-2 border border-brutalist-white/20 bg-brutalist-white/5 text-brutalist-white/60">
                    {tech}
                  </li>
                ))}
              </ul>

              <div class="flex items-center gap-6 pt-4 border-t border-brutalist-white/10">
                {project.sourceUrl && (
                  <a
                    href={project.sourceUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-sm font-medium tracking-wider uppercase text-brutalist-white/70 hover:text-brutalist-blue transition-colors"
                  >
                    <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                    </svg>
                    {t.projects.code}
                  </a>
                )}
                {project.websiteUrl && (
                  <a
                    href={project.websiteUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-sm font-medium tracking-wider uppercase text-brutalist-white/70 hover:text-brutalist-blue transition-colors"
                  >
                    <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    {t.projects.visit}
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>