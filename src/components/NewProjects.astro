---
import { PROJECTS } from "@/constants/projects";
import type { TranslationKeys } from "@/i18n";
import { getTranslations } from "@/i18n";

interface Props {
  locale: "en" | "es";
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section id="projects" class="relative py-14 sm:py-20 md:py-24 overflow-hidden">
  <div class="absolute inset-0 bg-brutalist-black"></div>
  <div class="absolute inset-0 bg-section-pattern opacity-60"></div>
  <div class="absolute inset-x-0 top-0 h-40 bg-section-fade-top"></div>
  <div class="absolute inset-x-0 bottom-0 h-40 bg-section-fade-bottom"></div>
  <div class="absolute top-1/4 left-1/4 w-1/2 h-1/2 bg-section-glow"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 md:px-8 lg:px-8">
    <div class="animate-on-scroll mb-16 text-center sm:text-left">
      <span class="inline-block text-center sm:text-left text-brutalist-white text-xs font-medium tracking-[0.3em] uppercase mb-2">
        {t.projects.subtitle}
      </span>
      <h2
        class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-brutalist-white title-fade"
        data-title={`${t.projects.title} ${t.projects.highlight}`}
      >
        {t.projects.title} {t.projects.highlight}
      </h2>
      <div class="title-rule mt-3 w-full h-1"></div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {PROJECTS.map((project, index) => (
        <div class={`animate-on-scroll ${index === 1 ? 'delay-100' : index === 2 ? 'delay-200' : ''}`}>
          <div class="relative bg-brutalist-white/5 backdrop-blur-sm border border-brutalist-white/10 overflow-hidden h-full">
            <div class="p-5 sm:p-6 space-y-6">
              <div class="space-y-3">
                <h3 class="text-2xl font-semibold tracking-tight text-brutalist-white">
                  {project.title}
                </h3>
              </div>

              <p class="text-base font-normal leading-relaxed text-brutalist-white/85">
                {t.projects.items[project.id as keyof typeof t.projects.items] || project.description}
              </p>

              <div class="flex items-center gap-6 pt-4 border-t border-brutalist-white/10">
                {project.sourceUrl && (
                  <a
                    href={project.sourceUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-sm font-medium tracking-wider uppercase text-brutalist-white/70 hover:text-brutalist-blue transition-colors"
                  >
                    <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                    </svg>
                    {t.projects.code}
                  </a>
                )}
                {project.websiteUrl && (
                  <a
                    href={project.websiteUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-sm font-medium tracking-wider uppercase text-brutalist-white/70 hover:text-brutalist-blue transition-colors"
                  >
                    <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    {t.projects.visit}
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
