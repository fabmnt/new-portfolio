---
import type { TranslationKeys } from "@/i18n";
import { getTranslations } from "@/i18n";

interface Props {
  locale: "en" | "es";
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<div class="space-y-6 md:space-y-8">
  <div class="space-y-5 md:space-y-6">
    <div class="w-full text-center sm:text-left">
      <h2
        class="max-w-xl uppercase text-balance text-3xl font-bold leading-tight text-brutalist-white sm:text-4xl md:text-4xl lg:text-5xl"
      >
        {t.hero.headline}
      </h2>
    </div>

    <p
      class="lg:text-lg text-pretty lg:max-w-[38ch] text-brutalist-white font-light leading-relaxed text-left"
    >
      {t.hero.description1}
    </p>
  </div>

  <div
    class="pt-1 flex flex-col items-center gap-3 sm:flex-row sm:flex-wrap sm:gap-4 sm:items-start sm:justify-start"
  >
    <a
      href="#experience"
      class="primary-metal-button group w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-4 text-center text-sm font-medium tracking-wider text-brutalist-white uppercase sm:px-8"
    >
      {t.hero.viewExperience}
    </a>
    <a
      href="#skills"
      class="secondary-metal-button w-full sm:w-auto inline-flex items-center justify-center gap-2 border border-brutalist-white/20 px-6 py-4 text-center text-sm font-medium tracking-wider text-brutalist-white uppercase sm:px-8"
    >
      {t.hero.viewSkills}
    </a>
  </div>
</div>
