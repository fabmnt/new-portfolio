---
import type { TranslationKeys } from "@/i18n";
import { getTranslations } from "@/i18n";

interface Props {
  locale: "en" | "es";
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<div class="space-y-6 md:space-y-8">
  <div class="space-y-5 md:space-y-6">
    <div class="w-full text-center sm:text-left">
      <span class="inline-block text-brutalist-white text-xs font-medium tracking-[0.3em] uppercase mb-2">
        {t.hero.aboutMe}
      </span>
      <h2 class="max-w-xl text-3xl font-bold leading-tight text-brutalist-white sm:text-4xl md:text-4xl lg:text-5xl">
        {t.hero.headline} {t.hero.highlight}
        {t.hero.headlineSuffix && ` ${t.hero.headlineSuffix}`}
      </h2>
    </div>

    <p class="text-lg text-brutalist-white/85 font-light leading-relaxed text-left">
      {t.hero.description1}
    </p>
  </div>

  <div class="pt-1 flex flex-col items-center gap-3 sm:flex-row sm:flex-wrap sm:gap-4 sm:items-start sm:justify-start">
    <a
      href="#experience"
      class="primary-metal-button group w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-4 text-center text-sm font-medium tracking-wider text-brutalist-white uppercase sm:px-8"
    >
      {t.hero.viewExperience}
      <svg class="size-4 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
    <a
      href="#projects"
      class="secondary-metal-button w-full sm:w-auto inline-flex items-center justify-center gap-2 border border-brutalist-white/20 px-6 py-4 text-center text-sm font-medium tracking-wider text-brutalist-white uppercase sm:px-8"
    >
      {t.hero.viewProjects}
    </a>
  </div>
</div>
