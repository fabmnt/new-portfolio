---
import type { TranslationKeys } from "@/i18n";
import { getTranslations } from "@/i18n";

interface Props {
  locale: "en" | "es";
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section id="about" class="space-y-6 scroll-mt-8 md:space-y-8 sm:scroll-mt-12 lg:scroll-mt-16">
  <div class="space-y-5 md:space-y-6">
    <div class="w-full text-center sm:text-left">
      <h2
        class="max-w-xl uppercase text-balance text-3xl font-bold leading-tight text-brutalist-white sm:text-4xl md:text-4xl lg:text-5xl"
      >
        {t.hero.headline}
      </h2>
    </div>

    <p
      class="lg:text-lg text-pretty lg:max-w-[38ch] text-brutalist-white/70 font-light leading-relaxed text-left"
    >
      {t.hero.description1}
    </p>
  </div>

</section>
