---
import AstroIcon from "@/assets/icons/AstroIcon.astro";
import ReactIcon from "@/assets/icons/ReactIcon.astro";
import AngularIcon from "@/assets/icons/AngularIcon.astro";
import ClaudeIcon from "@/assets/icons/ClaudeIcon.astro";
import CodexIcon from "@/assets/icons/CodexIcon.astro";
import NextJsIcon from "@/assets/icons/NextJsIcon.astro";
import OpencodeIcon from "@/assets/icons/OpencodeIcon.astro";
import TypeScriptIcon from "@/assets/icons/TypeScriptIcon.astro";
import PythonIcon from "@/assets/icons/PythonIcon.astro";
import type { TranslationKeys } from "@/i18n";
import { getTranslations } from "@/i18n";

interface Props {
  locale: "en" | "es";
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const skills = [
  { name: "Astro", color: "#FF5D01", Icon: AstroIcon },
  { name: "React", color: "#00D8FF", Icon: ReactIcon },
  { name: "Angular", color: "#c3002f", Icon: AngularIcon },
  { name: "Next.js", color: "#FFFFFF", Icon: NextJsIcon },
  { name: "TypeScript", color: "#3178c6", Icon: TypeScriptIcon },
  { name: "Python", color: "#4584b6", Icon: PythonIcon },
];

const agents = [
  { name: "Codex", color: "#6E7BFF", Icon: CodexIcon },
  { name: "Claude", color: "#D97757", Icon: ClaudeIcon },
  { name: "OpenCode", color: "#F3F4F6", Icon: OpencodeIcon },
];
---

<section
  id="skills"
  class="relative py-14 sm:py-20 md:py-24 lg:py-20 overflow-hidden"
>
  <div class="absolute inset-0 bg-brutalist-black"></div>
  <div class="absolute inset-0 bg-section-pattern opacity-60"></div>
  <div class="absolute inset-x-0 top-0 h-40 bg-section-fade-top"></div>
  <div class="absolute inset-x-0 bottom-0 h-40 bg-section-fade-bottom"></div>
  <div class="absolute top-1/3 left-1/3 w-1/3 h-1/3 bg-section-glow"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 md:px-8 lg:px-8">
    <div class="animate-on-scroll mb-16">
      <h2
        class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold text-brutalist-white title-fade"
        data-title={t.skills.title}
      >
        {t.skills.title}
      </h2>
      <div class="title-rule mt-3 w-full h-[2px] text-brutalist-white/85"></div>
      <p class="mt-4 text-brutalist-white/80">
        {t.skills.description}
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      {
        skills.map((skill, index) => (
          <div
            class={`animate-on-scroll ${index === 1 ? "delay-100" : index === 2 ? "delay-200" : index === 3 ? "delay-300" : index === 4 ? "delay-400" : index === 5 ? "delay-500" : ""}`}
          >
            <div
              class="skill-card relative p-6 bg-brutalist-white/5 backdrop-blur-sm border border-brutalist-white/10"
              data-hover-light
              style={`--skill-color: ${skill.color}; --skill-color-soft: ${skill.color}22; --skill-color-glow: ${skill.color}55;`}
            >
              <div class="skill-card-content relative z-10 flex flex-col items-center gap-4">
                <div
                  class="skill-icon-shell w-16 h-16 flex items-center justify-center"
                  style={`background-color: ${skill.color}20`}
                >
                  <skill.Icon class="!size-8" style={`color: ${skill.color}`} />
                </div>
                <span class="text-sm font-medium tracking-wider uppercase text-brutalist-white/90">
                  {skill.name}
                </span>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <details
      class="animate-on-scroll delay-300 mt-10 skill-tools-disclosure group"
    >
      <summary class="skill-tools-summary">
        <span>{t.skills.showMore}</span>
        <svg
          class="skill-tools-summary__icon size-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width={2}
            d="M19 9l-7 7-7-7"></path>
        </svg>
      </summary>

      <div class="skill-tools-panel">
        {
          t.skills.tools.map((tool) => (
            <span
              class="secondary-skill-badge px-4 py-2 bg-brutalist-white/5 border border-brutalist-white/10 text-brutalist-white/85 text-xs font-medium tracking-wider uppercase"
              data-hover-light
            >
              <span class="secondary-skill-badge__label">{tool}</span>
            </span>
          ))
        }
      </div>
    </details>

    <div class="mt-16 sm:mt-20">
      <div class="animate-on-scroll mb-8 space-y-2">
        <h3
          class="text-lg font-medium capitalize text-brutalist-white sm:text-xl"
        >
          {t.skills.agents.title}
        </h3>
        <p class="text-sm leading-relaxed text-brutalist-white/70 sm:text-base">
          {t.skills.agents.description}
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {
          agents.map((agent, index) => (
            <div
              class={`animate-on-scroll ${index === 1 ? "delay-100" : index === 2 ? "delay-200" : ""}`}
            >
              <div
                class="agent-card relative overflow-hidden border border-brutalist-white/10 bg-brutalist-white/5 p-6 backdrop-blur-sm"
                data-hover-light
                style={`--agent-color: ${agent.color}; --agent-color-soft: ${agent.color}22; --agent-color-glow: ${agent.color}55;`}
              >
                <div class="relative z-10 flex h-full flex-col justify-between gap-8">
                  <div class="flex items-start justify-between gap-4">
                    <div class="space-y-3">
                      <h4 class="text-2xl font-semibold tracking-tight text-brutalist-white">
                        {agent.name}
                      </h4>
                    </div>
                    <div
                      class="agent-icon-shell flex h-16 w-16 items-center justify-center rounded-full border border-brutalist-white/10"
                      style={`background-color: ${agent.color}16;`}
                    >
                      <agent.Icon
                        class="!size-9"
                        style={`color: ${agent.color}`}
                      />
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <style>
    .skill-card {
      --hover-x: 50%;
      --hover-y: 0%;
      overflow: hidden;
      transition:
        border-color 0.35s ease,
        background-color 0.35s ease,
        box-shadow 0.35s ease;
      isolation: isolate;
    }

    .skill-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(
        circle 140px at var(--hover-x) var(--hover-y),
        var(--skill-color-glow) 0%,
        var(--skill-color-soft) 26%,
        transparent 68%
      );
      opacity: 0;
      transform: scale(0.92);
      transition:
        opacity 0.35s ease,
        transform 0.35s ease;
      z-index: 0;
      pointer-events: none;
    }

    .skill-card::after {
      content: "";
      position: absolute;
      inset: 1px;
      border: 1px solid transparent;
      background: radial-gradient(
        circle 120px at var(--hover-x) var(--hover-y),
        var(--skill-color-glow) 0%,
        transparent 58%
      );
      opacity: 0;
      mix-blend-mode: screen;
      transition: opacity 0.35s ease;
      z-index: 0;
      pointer-events: none;
    }

    .skill-icon-shell {
      transition:
        transform 0.35s ease,
        box-shadow 0.35s ease,
        background-color 0.35s ease;
    }

    .skill-card:hover,
    .skill-card[data-touch-active="true"] {
      border-color: var(--skill-color-glow);
      background-color: var(--skill-color-soft);
      box-shadow: 0 18px 40px -20px var(--skill-color-glow);
    }

    .skill-card:hover::before,
    .skill-card:hover::after,
    .skill-card[data-touch-active="true"]::before,
    .skill-card[data-touch-active="true"]::after {
      opacity: 1;
    }

    .skill-card:hover::before,
    .skill-card[data-touch-active="true"]::before {
      transform: scale(1);
    }

    .skill-card:hover .skill-icon-shell,
    .skill-card[data-touch-active="true"] .skill-icon-shell {
      transform: translateY(-3px) scale(1.06);
      box-shadow: 0 0 24px -8px var(--skill-color-glow);
      background-color: var(--skill-color-soft) !important;
    }

    .agent-card {
      --hover-x: 50%;
      --hover-y: 0%;
      transition:
        transform 0.35s ease,
        border-color 0.35s ease,
        background-color 0.35s ease,
        box-shadow 0.35s ease;
      isolation: isolate;
    }

    .agent-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          circle 180px at var(--hover-x) var(--hover-y),
          var(--agent-color-glow) 0%,
          transparent 62%
        ),
        linear-gradient(
          135deg,
          rgb(255 255 255 / 0.06) 0%,
          transparent 48%,
          rgb(255 255 255 / 0.03) 100%
        );
      opacity: 0;
      transition: opacity 0.35s ease;
      pointer-events: none;
    }

    .agent-card::after {
      content: "";
      position: absolute;
      inset: 1px;
      border: 1px solid transparent;
      background: linear-gradient(
        135deg,
        var(--agent-color-glow) 0%,
        transparent 34%,
        transparent 66%,
        var(--agent-color-glow) 100%
      );
      opacity: 0;
      mix-blend-mode: screen;
      transition: opacity 0.35s ease;
      pointer-events: none;
    }

    .agent-icon-shell {
      transition:
        transform 0.35s ease,
        box-shadow 0.35s ease,
        background-color 0.35s ease,
        border-color 0.35s ease;
    }

    .agent-card:hover,
    .agent-card[data-touch-active="true"] {
      transform: translateY(-4px);
      border-color: var(--agent-color-glow);
      background-color: var(--agent-color-soft);
      box-shadow: 0 20px 40px -24px var(--agent-color-glow);
    }

    .agent-card:hover::before,
    .agent-card:hover::after,
    .agent-card[data-touch-active="true"]::before,
    .agent-card[data-touch-active="true"]::after {
      opacity: 1;
    }

    .agent-card:hover .agent-icon-shell,
    .agent-card[data-touch-active="true"] .agent-icon-shell {
      transform: scale(1.05);
      border-color: var(--agent-color-glow);
      background-color: var(--agent-color-soft) !important;
      box-shadow: 0 0 28px -10px var(--agent-color-glow);
    }

    .skill-tools-disclosure {
      border: 1px solid rgb(255 255 255 / 0.1);
      background: rgb(255 255 255 / 0.04);
      backdrop-filter: blur(12px);
      overflow: hidden;
    }

    .skill-tools-summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.25rem;
      cursor: pointer;
      list-style: none;
      padding: 1.2rem 1.5rem;
      color: rgb(255 255 255 / 0.88);
      font-size: 1rem;
      font-weight: 500;
      letter-spacing: 0;
      text-transform: none;
      line-height: 1.35;
      transition:
        color 0.3s ease,
        background-color 0.3s ease;
    }

    .skill-tools-summary::-webkit-details-marker {
      display: none;
    }

    .skill-tools-disclosure[open] .skill-tools-summary {
      color: rgb(255 255 255 / 0.92);
      background-color: rgb(255 255 255 / 0.025);
    }

    .skill-tools-summary__icon {
      flex-shrink: 0;
      opacity: 0.8;
      transition:
        transform 0.3s ease,
        opacity 0.3s ease;
    }

    .skill-tools-disclosure[open] .skill-tools-summary__icon {
      transform: rotate(180deg);
      opacity: 1;
    }

    .skill-tools-panel {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-start;
      gap: 0.85rem;
      padding: 1.35rem 1.5rem 1.5rem;
      border-top: 1px solid rgb(255 255 255 / 0.06);
    }

    .secondary-skill-badge {
      --hover-x: 50%;
      --hover-y: 0%;
      position: relative;
      overflow: hidden;
      isolation: isolate;
      transition:
        transform 0.3s ease,
        border-color 0.3s ease,
        color 0.3s ease,
        background-color 0.3s ease,
        box-shadow 0.3s ease;
    }

    .secondary-skill-badge__label {
      position: relative;
      z-index: 1;
    }

    .secondary-skill-badge::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(
        circle 90px at var(--hover-x) var(--hover-y),
        rgb(29 161 242 / 0.18) 0%,
        rgb(29 161 242 / 0.1) 24%,
        transparent 72%
      );
      opacity: 0;
      transform: scale(0.96);
      transition:
        opacity 0.3s ease,
        transform 0.3s ease;
      z-index: 0;
      pointer-events: none;
    }

    .secondary-skill-badge::after {
      content: "";
      position: absolute;
      inset: 1px;
      border: 1px solid transparent;
      background: radial-gradient(
        circle 70px at var(--hover-x) var(--hover-y),
        rgb(29 161 242 / 0.28) 0%,
        transparent 62%
      );
      opacity: 0;
      transition: opacity 0.3s ease;
      mix-blend-mode: screen;
      z-index: 0;
      pointer-events: none;
    }

    .secondary-skill-badge:hover,
    .secondary-skill-badge[data-touch-active="true"] {
      transform: translateY(-3px);
      border-color: rgb(29 161 242 / 0.45);
      color: rgb(168 232 255 / 1);
      background-color: rgb(255 255 255 / 0.08);
      box-shadow: 0 12px 24px -20px rgb(29 161 242 / 0.55);
    }

    .secondary-skill-badge:hover::before,
    .secondary-skill-badge:hover::after,
    .secondary-skill-badge[data-touch-active="true"]::before,
    .secondary-skill-badge[data-touch-active="true"]::after {
      opacity: 1;
    }

    .secondary-skill-badge:hover::before,
    .secondary-skill-badge[data-touch-active="true"]::before {
      transform: scale(1);
    }
  </style>
</section>
