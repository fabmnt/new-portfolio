---
import { getTranslations } from "@/i18n";

interface Props {
  locale: "en" | "es";
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const experiences = t.experience.items;
---

<section
  id="experience"
  class="relative py-14 sm:py-20 md:py-24 lg:py-20 overflow-hidden"
>
  <div class="absolute inset-0 bg-brutalist-black"></div>
  <div class="absolute inset-0 bg-section-pattern opacity-60"></div>
  <div class="absolute inset-x-0 top-0 h-40 bg-section-fade-top"></div>
  <div class="absolute inset-x-0 bottom-0 h-40 bg-section-fade-bottom"></div>
  <div class="absolute top-1/3 right-0 w-1/2 h-1/2 bg-section-glow"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 md:px-8 lg:px-8">
    <div class="animate-on-scroll mb-16">
      <div class="text-center sm:text-left">
        <h2
          class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold text-brutalist-white title-fade"
          data-title={`${t.experience.title}`}
        >
          {t.experience.title}
        </h2>
      </div>
      <div class="title-rule mt-3 w-full h-[2px] text-brutalist-white/85"></div>
      <!-- <p class="mt-4 text-left text-brutalist-white/70">
        {t.experience.description}
      </p> -->
    </div>

    <div class="relative space-y-8 sm:space-y-12 lg:space-y-16">
      {
        experiences.map((exp, index) => (
          <div class={`animate-on-scroll ${index === 1 ? "delay-100" : ""}`}>
            <div class="relative z-10 flex flex-col gap-4 lg:items-start">
              <div class="flex items-center gap-2 flex-col lg:flex-row justify-between w-full">
                <div class="flex flex-col items-center lg:items-start">
                  <span class="text-xs font-medium uppercase text-brutalist-white/85">
                    {exp.period}
                  </span>

                  <span class="text-sm font-normal text-brutalist-white/85">
                    {exp.role}
                  </span>
                </div>
                <div>
                  <a
                    href={exp.companyUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${locale === "es" ? "Visitar" : "Visit"} ${exp.company} (${locale === "es" ? "abre en nueva pestaña" : "opens in new tab"})`}
                    class="inline-flex items-center gap-1 text-brutalist-white hover:text-brutalist-blue transition-colors group"
                  >
                    <span class="text-lg">{exp.company}</span>
                    <svg
                      class="size-4 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width={2}
                        d="M7 17L17 7M17 7H7M17 7V17"
                      />
                    </svg>
                  </a>
                </div>
              </div>

              <div
                class="subtle-hover-card w-full border border-brutalist-white/10 bg-brutalist-white/5 p-5 backdrop-blur-sm sm:p-6 lg:p-5"
                data-hover-light
              >
                <div class="relative z-10 space-y-4 lg:space-y-3">
                  {/* <p class="text-base font-light leading-relaxed text-brutalist-white/85">
                    {exp.description}
                  </p> */}
                  <ul class="space-y-4 lg:space-y-3">
                    {exp.achievements.map((item) => (
                      <li class="flex items-start gap-3 text-base font-light leading-relaxed text-brutalist-white/85 lg:gap-2.5 lg:text-[0.9rem] lg:leading-6">
                        <span class="text-brutalist-white flex-shrink-0 flex items-center justify-center leading-none mt-[0.35em] lg:mt-[0.3em]">
                          <svg
                            class="size-3 lg:size-2.5"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                          >
                            <path
                              fill-rule="evenodd"
                              d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                              clip-rule="evenodd"
                            />
                          </svg>
                        </span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <details
      class="animate-on-scroll delay-300 mt-10 experience-other-disclosure group"
    >
      <summary class="experience-other-summary">
        <span>{t.experience.otherExperience.title}</span>
        <svg
          class="experience-other-summary__icon size-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width={2}
            d="M19 9l-7 7-7-7"></path>
        </svg>
      </summary>

      <div class="experience-other-panel">
        <p class="experience-other-text text-sm text-brutalist-white/85">
          {t.experience.otherExperience.description}
        </p>
      </div>
    </details>
  </div>

  <style>
    .experience-other-disclosure {
      border: 1px solid rgb(255 255 255 / 0.1);
      background: rgb(255 255 255 / 0.04);
      backdrop-filter: blur(12px);
      overflow: hidden;
    }

    .experience-other-summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.25rem;
      cursor: pointer;
      list-style: none;
      padding: 1.2rem 1.5rem;
      transition:
        color 0.3s ease,
        background-color 0.3s ease;
    }

    .experience-other-summary::-webkit-details-marker {
      display: none;
    }

    .experience-other-disclosure[open] .experience-other-summary {
      color: rgb(255 255 255 / 0.92);
      background-color: rgb(255 255 255 / 0.025);
    }

    .experience-other-summary__icon {
      flex-shrink: 0;
      opacity: 0.8;
      transition:
        transform 0.3s ease,
        opacity 0.3s ease;
    }

    .experience-other-disclosure[open] .experience-other-summary__icon {
      transform: rotate(180deg);
      opacity: 1;
    }

    .experience-other-panel {
      padding: 1.35rem 1.5rem 1.5rem;
      border-top: 1px solid rgb(255 255 255 / 0.06);
      background: rgb(255 255 255 / 0.015);
    }
  </style>
</section>
