---
import HoverLightScript from "./HoverLightScript.astro";
import type { TranslationKeys } from "@/i18n";
import { getTranslations } from "@/i18n";

interface Props {
  locale: "en" | "es";
}

const { locale } = Astro.props;
const t = getTranslations(locale);

interface StatProps {
  value: string;
  label: string;
}

const stats: StatProps[] = [
  { value: "4+", label: t.hero.yearsExperience },
  { value: "50+", label: t.hero.projectsCompleted },
];
---

<div class="grid grid-cols-2 gap-4 sm:gap-6 lg:gap-8">
  {
    stats.map((stat) => (
      <div
        class="subtle-hover-card border border-brutalist-white/10 bg-brutalist-white/5 p-4 sm:p-5"
        data-hover-light
      >
        <div class="relative z-10">
          <div class="mb-2 text-2xl font-semibold text-brutalist-white sm:text-4xl">
            {stat.value}
          </div>
          <div class="text-xs font-medium tracking-[0.2em] uppercase sm:text-sm">
            {stat.label}
          </div>
        </div>
      </div>
    ))
  }
  <div
    class="subtle-hover-card col-span-2 border border-brutalist-white/10 bg-brutalist-white/5 p-4 sm:p-5"
    data-hover-light
  >
    <ul class="relative z-10 space-y-2">
      {
        t.hero.promises.map((promise) => (
          <li class="flex items-start gap-3 text-sm font-light leading-relaxed text-brutalist-white/85">
            <span class="text-brutalist-white mt-1.5 flex-shrink-0">
              <svg class="size-3" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"
                />
              </svg>
            </span>
            {promise}
          </li>
        ))
      }
    </ul>
  </div>
</div>

<HoverLightScript />
