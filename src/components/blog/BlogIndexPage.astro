---
import Layout from "@/layouts/NewLayout.astro";
import { getTranslations, type Locale } from "@/i18n";
import { formatBlogDate, getBlogPath, type BlogEntry } from "@/lib/blog";

interface Props {
  locale: Locale;
  posts: BlogEntry[];
}

const { locale, posts } = Astro.props;
const t = getTranslations(locale);
const homePath = locale === "en" ? "/en" : "/";
const blogLeadWord = locale === "en" ? "My" : "Mi";
const pageTitle = "Blog | Fabian Montoya";
const pageDescription = t.blog.description;
const pageKeywords =
  locale === "en"
    ? "Fabian Montoya blog, Astro blog, web development articles, automation, AI integrations"
    : "blog de Fabian Montoya, blog con Astro, articulos de desarrollo web, automatizacion, integraciones con IA";
---

<Layout
  locale={locale}
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
>
  <main id="main-content" class="relative min-h-screen overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(59,130,246,0.18),_transparent_48%),linear-gradient(180deg,_rgba(255,255,255,0.02)_0%,_transparent_100%)]"
    >
    </div>

    <section class="max-w-5xl mx-auto relative border-b border-white/10">
      <div class="mx-auto px-6 py-20 sm:px-8 lg:px-10">
        <div
          class="flex flex-wrap items-center gap-2 text-[10px] font-semibold uppercase tracking-[0.16em] text-white/55 sm:text-[11px]"
        >
          <a href={homePath} class="transition hover:text-white">
            {t.blog.viewPortfolio}
          </a>
        </div>

        <div class="mt-8 max-w-3xl">
          <h1
            class="text-5xl font-semibold leading-none tracking-tight text-white sm:text-6xl"
          >
            <span>{blogLeadWord} </span>
            <span class="text-brutalist-blue">Blog</span>
          </h1>
          <p class="mt-6 text-lg text-white/72">
            {t.blog.description}
          </p>
        </div>
      </div>
    </section>

    <section class="relative mx-auto max-w-5xl px-6 py-16 sm:px-8 lg:px-10">
      {
        posts.length > 0 ? (
          <>
            <h2 class="mb-6 text-2xl font-semibold tracking-tight text-white sm:text-3xl">
              {t.blog.latestPosts}
            </h2>

            <div class="grid gap-6 md:grid-cols-2">
              {posts.map((post) => (
                <article
                  class="subtle-hover-card relative h-full overflow-hidden border border-brutalist-white/10 bg-brutalist-white/5 backdrop-blur-sm"
                  data-hover-light
                >
                  <div class="relative z-10 flex h-full flex-col p-5 sm:p-6 space-y-6">
                    <div class="space-y-3">
                      <p class="text-sm font-medium text-brutalist-white/50">
                        {formatBlogDate(post.data.publishDate, locale)}
                      </p>
                      <h3 class="text-2xl font-semibold tracking-tight text-brutalist-white">
                        <a
                          href={getBlogPath(post)}
                          class="transition-colors hover:text-brutalist-blue"
                        >
                          {post.data.title}
                        </a>
                      </h3>
                    </div>

                    <p class="text-base font-normal leading-relaxed text-brutalist-white/85">
                      {post.data.description}
                    </p>

                    {post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-2">
                        {post.data.tags.map((tag) => (
                          <span class="border border-brutalist-white/10 bg-brutalist-white/5 px-3 py-1 text-[11px] font-medium uppercase tracking-[0.18em] text-brutalist-white/70">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}

                    <div class="mt-auto flex items-center gap-6 border-t border-brutalist-white/10 pt-4">
                      <a
                        href={getBlogPath(post)}
                        class="inline-flex items-center gap-2 text-sm font-medium uppercase tracking-wider text-brutalist-white/70 transition-colors hover:text-brutalist-blue"
                      >
                        <svg
                          class="size-5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width={2}
                            d="M14 5l7 7-7 7M3 12h18"
                          />
                        </svg>
                        {t.blog.readArticle}
                      </a>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </>
        ) : (
          <div class="border border-dashed border-white/20 bg-white/[0.03] px-8 py-12 text-center">
            <h2 class="text-2xl font-semibold text-white">
              {t.blog.emptyTitle}
            </h2>
            <p class="mx-auto mt-4 max-w-xl text-white/68">
              {t.blog.emptyDescription}
            </p>
          </div>
        )
      }
    </section>
  </main>
</Layout>
