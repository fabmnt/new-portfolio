---
import Layout from "@/layouts/NewLayout.astro";
import { getTranslations, type Locale } from "@/i18n";
import { formatBlogDate, getBlogPath, type BlogEntry } from "@/lib/blog";

interface Props {
  locale: Locale;
  posts: BlogEntry[];
}

const { locale, posts } = Astro.props;
const t = getTranslations(locale);
const homePath = locale === "en" ? "/en" : "/";
const blogLeadWord = locale === "en" ? "My" : "Mi";
const pageTitle = "Blog | Fabian Montoya";
const pageDescription = t.blog.description;
const pageKeywords =
  locale === "en"
    ? "Fabian Montoya blog, Astro blog, web development articles, automation, AI integrations"
    : "blog de Fabian Montoya, blog con Astro, articulos de desarrollo web, automatizacion, integraciones con IA";
---

<Layout
  locale={locale}
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
>
  <main id="main-content" class="relative min-h-screen overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(59,130,246,0.18),_transparent_48%),linear-gradient(180deg,_rgba(255,255,255,0.02)_0%,_transparent_100%)]"
    >
    </div>

    <section class="relative mx-auto max-w-6xl">
      <div class="mx-auto px-5 pb-8 pt-16 sm:px-8 sm:py-16 lg:px-10">
        <div
          class="flex flex-wrap items-center gap-2 text-xs uppercase tracking-[0.24em] text-white/55"
        >
          <a href={homePath} class="transition hover:text-white">
            {t.blog.viewPortfolio}
          </a>
        </div>

        <div class="mt-2 max-w-4xl text-center sm:text-left">
          <h1
            class="text-4xl font-semibold leading-none tracking-tight text-white sm:text-6xl"
          >
            <span>{blogLeadWord} </span>
            <span class="text-brutalist-blue">Blog</span>
          </h1>
          <p class="mt-3 max-w-3xl text-base text-white/72 sm:mt-2 sm:text-lg">
            {t.blog.description}
          </p>
        </div>
      </div>
    </section>

    <section class="relative pb-8 pt-4 sm:py-8">
      <div class="relative z-10 left-1/2 w-[calc(100vw-0.5rem)] max-w-none -translate-x-1/2 sm:w-[98vw]">
        <div
          class="blog-content-shell rounded-[1.5rem] border border-zinc-900 bg-black/80 px-3 py-8 sm:rounded-[2rem] sm:px-6 sm:py-10 lg:px-10 lg:py-12"
        >
          <div class="mx-auto max-w-6xl px-0 sm:px-6 md:px-8 lg:px-8">
            {
              posts.length > 0 ? (
                <>
                  <h2 class="mb-6 text-2xl font-semibold tracking-tight text-white sm:mb-8 sm:text-3xl">
                    {t.blog.latestPosts}
                  </h2>

                  <div class="grid gap-6 md:grid-cols-2">
                    {posts.map((post) => (
                      <article
                        class="subtle-hover-card relative h-full overflow-hidden border border-brutalist-white/10 bg-brutalist-white/5 backdrop-blur-sm"
                        data-hover-light
                      >
                        <div class="relative z-10 flex h-full flex-col space-y-5 px-4 py-5 sm:space-y-6 sm:p-6">
                          <div class="space-y-3">
                            <p class="text-sm font-medium text-brutalist-white/50">
                              {formatBlogDate(post.data.publishDate, locale)}
                            </p>
                            <h3 class="text-xl font-semibold tracking-tight text-brutalist-white sm:text-2xl">
                              <a
                                href={getBlogPath(post)}
                                class="transition-colors hover:text-brutalist-blue"
                              >
                                {post.data.title}
                              </a>
                            </h3>
                          </div>

                          <p class="text-base font-normal leading-relaxed text-brutalist-white/85">
                            {post.data.description}
                          </p>

                          {post.data.tags.length > 0 && (
                            <div class="flex flex-wrap gap-2">
                              {post.data.tags.map((tag) => (
                                <span class="border border-brutalist-white/10 bg-brutalist-white/5 px-2.5 py-1 text-[10px] font-medium uppercase tracking-[0.18em] text-brutalist-white/70 sm:px-3 sm:text-[11px]">
                                  {tag}
                                </span>
                              ))}
                            </div>
                          )}

                          <div class="mt-auto flex items-center gap-4 border-t border-brutalist-white/10 pt-4 sm:gap-6">
                            <a
                              href={getBlogPath(post)}
                              class="inline-flex items-center gap-2 text-xs font-medium uppercase tracking-[0.18em] text-brutalist-white/70 transition-colors hover:text-brutalist-blue sm:text-sm sm:tracking-wider"
                            >
                              <svg
                                class="size-5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                aria-hidden="true"
                              >
                                <path
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  stroke-width={2}
                                  d="M14 5l7 7-7 7M3 12h18"
                                />
                              </svg>
                              {t.blog.readArticle}
                            </a>
                          </div>
                        </div>
                      </article>
                    ))}
                  </div>
                </>
              ) : (
                <div class="border border-dashed border-white/20 bg-white/[0.03] px-8 py-12 text-center">
                  <h2 class="text-2xl font-semibold text-white">
                    {t.blog.emptyTitle}
                  </h2>
                  <p class="mx-auto mt-4 max-w-xl text-white/68">
                    {t.blog.emptyDescription}
                  </p>
                </div>
              )
            }
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .blog-content-shell {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    box-shadow:
      0 16px 40px rgb(0 0 0 / 0.2),
      0 32px 90px rgb(0 0 0 / 0.28);
  }

  .blog-content-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.12),
      inset 0 -1px 0 rgb(255 255 255 / 0.04),
      inset 0 0 18px rgb(255 255 255 / 0.025);
  }
</style>
