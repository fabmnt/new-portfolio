---
import { render } from "astro:content";
import Layout from "@/layouts/NewLayout.astro";
import { getTranslations, type Locale } from "@/i18n";
import { formatBlogDate, type BlogEntry } from "@/lib/blog";

interface Props {
  locale: Locale;
  post: BlogEntry;
}

const { locale, post } = Astro.props;
const { Content } = await render(post);
const t = getTranslations(locale);
const blogPath = locale === "en" ? "/en/blog" : "/blog";
const homePath = locale === "en" ? "/en" : "/";
const pageTitle = `${post.data.title} | Blog | Fabian Montoya`;
const pageKeywords = [post.data.title, ...post.data.tags].join(", ");
const modifiedTime = (
  post.data.updatedDate ?? post.data.publishDate
).toISOString();
---

<Layout
  locale={locale}
  title={pageTitle}
  description={post.data.description}
  keywords={pageKeywords}
  ogType="article"
  publishedTime={post.data.publishDate.toISOString()}
  modifiedTime={modifiedTime}
>
  <main id="main-content" class="relative min-h-screen overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(59,130,246,0.18),_transparent_48%),linear-gradient(180deg,_rgba(255,255,255,0.02)_0%,_transparent_100%)]"
    >
    </div>

    <section class="relative mx-auto max-w-6xl">
      <div class="mx-auto px-5 pb-8 pt-16 sm:px-8 sm:py-16 lg:px-10">
        <div
          class="flex flex-wrap items-center gap-x-3 gap-y-2 text-xs uppercase tracking-[0.24em] text-white/55"
        >
          <a href={homePath} class="transition hover:text-white">
            {t.blog.viewPortfolio}
          </a>
          <span aria-hidden="true">/</span>
          <a href={blogPath} class="transition hover:text-white">
            {t.blog.backToBlog}
          </a>
        </div>

        <header class="mt-8 text-center sm:text-left">
          <h1
            class="text-3xl font-semibold tracking-tight text-white sm:text-5xl"
          >
            {post.data.title}
          </h1>
          <p class="mt-3 max-w-3xl text-base text-white/72 sm:mt-2 sm:text-lg">
            {post.data.description}
          </p>

          <div class="mt-8 flex flex-wrap gap-x-6 gap-y-3 text-sm text-white/56">
            <p>
              <span class="font-semibold text-white/80"
                >{t.blog.publishedOn}:</span
              >
              {" "}
              {formatBlogDate(post.data.publishDate, locale)}
            </p>
            {
              post.data.updatedDate && (
                <p>
                  <span class="font-semibold text-white/80">
                    {t.blog.updatedOn}:
                  </span>{" "}
                  {formatBlogDate(post.data.updatedDate, locale)}
                </p>
              )
            }
          </div>

          {
            post.data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="border border-white/12 bg-white/5 px-2.5 py-1 text-[10px] font-medium uppercase tracking-[0.18em] text-white/62 sm:px-3 sm:text-[11px]">
                    {tag}
                  </span>
                ))}
              </div>
            )
          }
        </header>
      </div>
    </section>

    <section class="relative pb-8 pt-4 sm:py-8">
      <div class="relative z-10 left-1/2 w-[calc(100vw-0.5rem)] max-w-none -translate-x-1/2 sm:w-[98vw]">
        <div
          class="blog-article-shell rounded-[1.5rem] border border-zinc-900 bg-black/80 px-3 py-8 sm:rounded-[2rem] sm:px-6 sm:py-10 lg:px-10 lg:py-12"
        >
          <article
            class="blog-markdown mx-auto max-w-6xl px-0 sm:px-6 md:px-8 lg:px-8"
          >
            <Content />
          </article>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .blog-article-shell {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    box-shadow:
      0 16px 40px rgb(0 0 0 / 0.2),
      0 32px 90px rgb(0 0 0 / 0.28);
  }

  .blog-article-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.12),
      inset 0 -1px 0 rgb(255 255 255 / 0.04),
      inset 0 0 18px rgb(255 255 255 / 0.025);
  }

  :global(.blog-markdown) {
    color: rgb(255 255 255 / 0.8);
    font-size: 1rem;
    line-height: 1.8;
  }

  :global(.blog-markdown > * + *) {
    margin-top: 1.25rem;
  }

  :global(.blog-markdown h2),
  :global(.blog-markdown h3),
  :global(.blog-markdown h4) {
    color: rgb(255 255 255);
    font-weight: 600;
    line-height: 1.2;
    margin-top: 2.75rem;
  }

  :global(.blog-markdown h2) {
    font-size: clamp(1.75rem, 1.4rem + 1vw, 2.3rem);
  }

  :global(.blog-markdown h3) {
    font-size: clamp(1.35rem, 1.15rem + 0.7vw, 1.75rem);
  }

  :global(.blog-markdown h4) {
    font-size: clamp(1.1rem, 1rem + 0.45vw, 1.35rem);
  }

  :global(.blog-markdown p),
  :global(.blog-markdown li) {
    color: rgb(255 255 255 / 0.78);
  }

  :global(.blog-markdown strong) {
    color: rgb(255 255 255 / 0.96);
    font-weight: 700;
  }

  :global(.blog-markdown em) {
    color: rgb(255 255 255 / 0.9);
  }

  :global(.blog-markdown a) {
    color: rgb(96 165 250);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  :global(.blog-markdown ul),
  :global(.blog-markdown ol) {
    margin: 1.5rem 0;
    padding-left: 1.75rem;
  }

  :global(.blog-markdown ul) {
    list-style: disc outside;
  }

  :global(.blog-markdown ol) {
    list-style: decimal outside;
  }

  :global(.blog-markdown ul ul) {
    list-style-type: circle;
  }

  :global(.blog-markdown ul ul ul) {
    list-style-type: square;
  }

  :global(.blog-markdown ol ol) {
    list-style-type: lower-alpha;
  }

  :global(.blog-markdown ol ol ol) {
    list-style-type: lower-roman;
  }

  :global(.blog-markdown li > ul),
  :global(.blog-markdown li > ol) {
    margin-top: 0.65rem;
    margin-bottom: 0.65rem;
  }

  :global(.blog-markdown li::marker) {
    color: rgb(255 255 255 / 0.58);
  }

  :global(.blog-markdown li + li) {
    margin-top: 0.45rem;
  }

  :global(.blog-markdown blockquote) {
    border-left: 3px solid rgb(59 130 246 / 0.9);
    background: rgb(255 255 255 / 0.03);
    border-radius: 0 0.75rem 0.75rem 0;
    margin-left: 0;
    padding: 0.85rem 1rem;
    color: rgb(255 255 255 / 0.68);
  }

  :global(.blog-markdown blockquote > *:first-child) {
    margin-top: 0;
  }

  :global(.blog-markdown blockquote > *:last-child) {
    margin-bottom: 0;
  }

  :global(.blog-markdown code) {
    background: rgb(255 255 255 / 0.08);
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: 0.35rem;
    color: rgb(248 250 252 / 0.95);
    font-size: 0.9em;
    padding: 0.15rem 0.4rem;
  }

  :global(.blog-markdown pre) {
    background: rgb(255 255 255 / 0.05);
    border: 1px solid rgb(255 255 255 / 0.12);
    overflow-x: auto;
    border-radius: 1rem;
    margin: 1.75rem 0;
    padding: 1rem;
  }

  :global(.blog-markdown pre code) {
    background: transparent;
    border: 0;
    display: block;
    padding: 0;
    white-space: pre;
  }

  :global(.blog-markdown hr) {
    border: 0;
    border-top: 1px solid rgb(255 255 255 / 0.12);
    margin: 2rem 0;
  }

  :global(.blog-markdown img) {
    border-radius: 1rem;
    display: block;
    height: auto;
    margin: 1.75rem auto;
    max-width: 100%;
  }

  :global(.blog-markdown table) {
    border-collapse: collapse;
    margin: 1.75rem 0;
    width: 100%;
  }

  :global(.blog-markdown th),
  :global(.blog-markdown td) {
    border: 1px solid rgb(255 255 255 / 0.12);
    padding: 0.8rem 0.9rem;
    text-align: left;
    vertical-align: top;
  }

  :global(.blog-markdown th) {
    color: rgb(255 255 255 / 0.95);
    font-weight: 600;
    background: rgb(255 255 255 / 0.04);
  }

  :global(.blog-markdown tbody tr:nth-child(even)) {
    background: rgb(255 255 255 / 0.02);
  }

  :global(.blog-markdown figure) {
    margin: 1.75rem 0;
  }

  :global(.blog-markdown figcaption) {
    color: rgb(255 255 255 / 0.55);
    font-size: 0.9rem;
    margin-top: 0.75rem;
    text-align: center;
  }
</style>
